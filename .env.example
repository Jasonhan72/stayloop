NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
ANTHROPIC_API_KEY=your_anthropic_api_key
CANLII_API_KEY=your_canlii_api_key

# Server-only Supabase admin key, used by the Stripe webhook and the
# landlord email notification route to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (landlord email notifications on new applications).
# 1. Sign up at resend.com (free tier = 3,000 emails/mo, 100/day)
# 2. Verify stayloop.ai as a sending domain (add DNS records)
# 3. Create an API key and paste below.
# RESEND_FROM must be an address on a verified domain, e.g.
#   "Stayloop <notifications@stayloop.ai>"
RESEND_API_KEY=re_...
RESEND_FROM="Stayloop <notifications@stayloop.ai>"

# Stripe — test keys for dev, live keys in Cloudflare Pages env for prod.
# 1. Create a Product "Stayloop Pro" in Stripe Dashboard
# 2. Add a recurring monthly price at $29 CAD (or USD)
# 3. Paste the price_... id into NEXT_PUBLIC_STRIPE_PRICE_ID
# 4. Install the Stripe CLI locally and run `stripe listen --forward-to
#    localhost:3000/api/stripe/webhook` to get a whsec_... dev signing secret.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRICE_ID=price_...

# Used to build Checkout success/cancel URLs. In prod: https://www.stayloop.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000
